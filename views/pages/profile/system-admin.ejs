<!-- System Administrator Profile Page -->
<div x-data="systemAdminProfile()" x-init="loadProfileData()" class="space-y-6">
    
    <!-- Page Header -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <div class="flex items-center justify-between">
            <div class="flex items-center space-x-4">
                <div class="h-16 w-16 bg-blue-600 rounded-full flex items-center justify-center">
                    <i class="fas fa-user-shield text-white text-2xl"></i>
                </div>
                <div>
                    <h1 class="text-2xl font-bold text-gray-900">Profile Settings</h1>
                    <p class="text-gray-600">Manage your system administrator account</p>
                </div>
            </div>
            <div class="flex items-center space-x-3">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    <i class="fas fa-shield-alt mr-2"></i>System Admin
                </span>
                <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    <i class="fas fa-check-circle mr-2"></i>Active
                </span>
            </div>
        </div>
    </div>

    <!-- Profile Information Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <i class="fas fa-user-circle text-blue-600 mr-2"></i>
                Account Information
            </h3>
            <button @click="editMode = !editMode" 
                    class="inline-flex items-center px-3 py-2 text-sm font-medium text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-lg transition-colors duration-200">
                <i class="fas mr-2" :class="editMode ? 'fa-times' : 'fa-edit'"></i>
                <span x-text="editMode ? 'Cancel' : 'Edit'"></span>
            </button>
        </div>
        
        <div class="p-6">
            <!-- Loading State -->
            <div x-show="loading" class="text-center py-8">
                <div class="inline-flex items-center justify-center h-8 w-8 animate-spin rounded-full border-2 border-gray-300 border-t-blue-600 mb-4"></div>
                <p class="text-sm text-gray-500">Loading profile...</p>
            </div>

            <!-- Profile Form -->
            <form x-show="!loading" @submit.prevent="saveProfile()" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Username -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-user mr-2 text-gray-400"></i>Username
                        </label>
                        <input type="text" x-model="profile.username" :readonly="!editMode"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors duration-200"
                               :class="editMode ? 'bg-white' : 'bg-gray-50 cursor-not-allowed'">
                    </div>

                    <!-- Email -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-envelope mr-2 text-gray-400"></i>Email Address
                        </label>
                        <input type="email" x-model="profile.email" :readonly="!editMode"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors duration-200"
                               :class="editMode ? 'bg-white' : 'bg-gray-50 cursor-not-allowed'">
                    </div>

                    <!-- Full Name -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-id-card mr-2 text-gray-400"></i>Full Name
                        </label>
                        <input type="text" x-model="profile.fullName" :readonly="!editMode"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm transition-colors duration-200"
                               :class="editMode ? 'bg-white' : 'bg-gray-50 cursor-not-allowed'">
                    </div>

                    <!-- Role -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-user-tag mr-2 text-gray-400"></i>Role
                        </label>
                        <input type="text" value="System Administrator" readonly
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm bg-gray-50 cursor-not-allowed sm:text-sm">
                    </div>

                    <!-- Created Date -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-calendar-plus mr-2 text-gray-400"></i>Account Created
                        </label>
                        <input type="text" :value="formatDate(profile.createdAt)" readonly
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm bg-gray-50 cursor-not-allowed sm:text-sm">
                    </div>

                    <!-- Last Login -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            <i class="fas fa-clock mr-2 text-gray-400"></i>Last Login
                        </label>
                        <input type="text" :value="formatDate(profile.lastLoginAt)" readonly
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm bg-gray-50 cursor-not-allowed sm:text-sm">
                    </div>
                </div>

                <!-- Save Button -->
                <div x-show="editMode" class="flex justify-end pt-4 border-t border-gray-200">
                    <button type="submit" :disabled="saving"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 transition-colors duration-200">
                        <span x-show="!saving" class="flex items-center">
                            <i class="fas fa-save mr-2"></i>Save Changes
                        </span>
                        <span x-show="saving" class="flex items-center">
                            <i class="fas fa-spinner fa-spin mr-2"></i>Saving...
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Security Settings Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <i class="fas fa-lock text-blue-600 mr-2"></i>
                Security Settings
            </h3>
        </div>
        
        <div class="p-6">
            <!-- Change Password -->
            <div class="border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors duration-200">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="h-10 w-10 bg-amber-100 rounded-lg flex items-center justify-center">
                            <i class="fas fa-key text-amber-600"></i>
                        </div>
                        <div>
                            <h4 class="text-sm font-medium text-gray-900">Password</h4>
                            <p class="text-sm text-gray-500">Last changed: <span x-text="formatDate(profile.passwordChangedAt)">Never</span></p>
                        </div>
                    </div>
                    <button @click="showChangePasswordModal = true"
                            class="inline-flex items-center px-3 py-2 text-sm font-medium text-amber-600 hover:text-amber-800 hover:bg-amber-50 rounded-lg transition-colors duration-200">
                        <i class="fas fa-edit mr-2"></i>Change Password
                    </button>
                </div>
            </div>

            <!-- Two-Factor Authentication (Future) -->
            <div class="mt-4 border border-gray-200 rounded-lg p-4 opacity-50">
                <div class="flex items-center justify-between">
                    <div class="flex items-center space-x-3">
                        <div class="h-10 w-10 bg-green-100 rounded-lg flex items-center justify-center">
                            <i class="fas fa-mobile-alt text-green-600"></i>
                        </div>
                        <div>
                            <h4 class="text-sm font-medium text-gray-900">Two-Factor Authentication</h4>
                            <p class="text-sm text-gray-500">Coming soon - Enhanced security</p>
                        </div>
                    </div>
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                        Coming Soon
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Change Password Modal -->
    <div x-show="showChangePasswordModal" 
         x-transition:enter="ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-50 overflow-y-auto"
         style="display: none;">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @click="showChangePasswordModal = false"></div>

            <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6"
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95">
                
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-amber-100 sm:mx-0 sm:h-10 sm:w-10">
                        <i class="fas fa-key text-amber-600"></i>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left flex-1">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Change Password</h3>
                        <div class="mt-2">
                            <p class="text-sm text-gray-500">Enter your current password and choose a new secure password.</p>
                        </div>
                    </div>
                </div>

                <form @submit.prevent="changePassword()" class="mt-6 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Current Password *</label>
                        <input type="password" x-model="passwordForm.currentPassword" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">New Password *</label>
                        <input type="password" x-model="passwordForm.newPassword" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password *</label>
                        <input type="password" x-model="passwordForm.confirmPassword" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm">
                    </div>

                    <div class="mt-6 sm:mt-6 sm:flex sm:flex-row-reverse">
                        <button type="submit" :disabled="changingPassword"
                                class="w-full inline-flex justify-center items-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50">
                            <span x-show="!changingPassword" class="flex items-center">
                                <i class="fas fa-save mr-2"></i>Update Password
                            </span>
                            <span x-show="changingPassword" class="flex items-center">
                                <i class="fas fa-spinner fa-spin mr-2"></i>Updating...
                            </span>
                        </button>
                        <button type="button" @click="showChangePasswordModal = false"
                                class="mt-3 w-full inline-flex justify-center rounded-lg border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:w-auto sm:text-sm">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function systemAdminProfile() {
    return {
        loading: true,
        editMode: false,
        saving: false,
        showChangePasswordModal: false,
        changingPassword: false,
        profile: {
            username: '',
            email: '',
            fullName: '',
            createdAt: null,
            lastLoginAt: null,
            passwordChangedAt: null
        },
        passwordForm: {
            currentPassword: '',
            newPassword: '',
            confirmPassword: ''
        },

        async loadProfileData() {
            try {
                this.loading = true;
                
                const response = await fetch('/api/v1/admin/system/profile', {
                    credentials: 'same-origin',
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    if (data.success && data.data) {
                        this.profile = {
                            username: data.data.username || '',
                            email: data.data.email || '',
                            fullName: data.data.full_name || data.data.username || '',
                            createdAt: data.data.created_at || new Date(),
                            lastLoginAt: data.data.last_login_at || new Date(),
                            passwordChangedAt: data.data.password_changed_at || data.data.created_at || new Date()
                        };
                    }
                } else if (response.status === 401) {
                    window.location.href = '/auth/login?redirect=' + encodeURIComponent(window.location.pathname);
                    return;
                } else {
                    console.error('Failed to load profile:', response.status);
                    if (window.notify) {
                        window.notify('error', 'Failed to load profile data');
                    }
                }
            } catch (error) {
                console.error('Profile load error:', error);
                if (window.notify) {
                    window.notify('error', 'Network error loading profile');
                }
            } finally {
                this.loading = false;
            }
        },

        async saveProfile() {
            if (!this.profile.username.trim() || !this.profile.email.trim()) {
                if (window.notify) window.notify('error', 'Please fill in required fields');
                return;
            }

            try {
                this.saving = true;
                
                const response = await fetch('/api/v1/admin/system/profile', {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify({
                        username: this.profile.username.trim(),
                        email: this.profile.email.trim(),
                        fullName: this.profile.fullName.trim()
                    })
                });

                if (response.ok) {
                    if (window.notify) {
                        window.notify('success', 'Profile updated successfully');
                    }
                    this.editMode = false;
                } else if (response.status === 401) {
                    window.location.href = '/auth/login?redirect=' + encodeURIComponent(window.location.pathname);
                } else {
                    const errorText = await response.text();
                    let errorMessage = 'Failed to update profile';
                    try {
                        const errorData = JSON.parse(errorText);
                        errorMessage = errorData.error?.message || errorMessage;
                    } catch {}
                    
                    if (window.notify) window.notify('error', errorMessage);
                }
            } catch (error) {
                console.error('Profile save error:', error);
                if (window.notify) window.notify('error', 'Network error saving profile');
            } finally {
                this.saving = false;
            }
        },

        async changePassword() {
            if (!this.passwordForm.currentPassword || !this.passwordForm.newPassword || !this.passwordForm.confirmPassword) {
                if (window.notify) window.notify('error', 'Please fill in all password fields');
                return;
            }

            if (this.passwordForm.newPassword !== this.passwordForm.confirmPassword) {
                if (window.notify) window.notify('error', 'New passwords do not match');
                return;
            }

            if (this.passwordForm.newPassword.length < 8) {
                if (window.notify) window.notify('error', 'New password must be at least 8 characters');
                return;
            }

            try {
                this.changingPassword = true;
                
                const response = await fetch('/api/v1/admin/system/auth/change-password', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify({
                        currentPassword: this.passwordForm.currentPassword,
                        newPassword: this.passwordForm.newPassword
                    })
                });

                if (response.ok) {
                    if (window.notify) {
                        window.notify('success', 'Password changed successfully');
                    }
                    this.showChangePasswordModal = false;
                    this.passwordForm = { currentPassword: '', newPassword: '', confirmPassword: '' };
                    this.profile.passwordChangedAt = new Date();
                } else {
                    const errorText = await response.text();
                    let errorMessage = 'Failed to change password';
                    try {
                        const errorData = JSON.parse(errorText);
                        errorMessage = errorData.error?.message || errorMessage;
                    } catch {}
                    
                    if (window.notify) window.notify('error', errorMessage);
                }
            } catch (error) {
                console.error('Password change error:', error);
                if (window.notify) window.notify('error', 'Network error changing password');
            } finally {
                this.changingPassword = false;
            }
        },

        formatDate(dateString) {
            if (!dateString) return 'Never';
            try {
                return new Date(dateString).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'long',
                    day: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit'
                });
            } catch {
                return 'Invalid date';
            }
        }
    };
}
</script>