<!-- System Administrator Dashboard - Reconstructed per Frontend Strategy -->
<div x-data="systemAdminDashboard()" x-init="loadDashboardData()" class="space-y-6">
    
    <!-- Welcome Header Section -->
    <div class="bg-gradient-to-br from-blue-600 to-blue-800 rounded-xl shadow-lg overflow-hidden">
        <div class="px-6 py-8 sm:px-8">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <div class="flex items-center space-x-4">
                        <div class="h-16 w-16 bg-white/20 rounded-xl flex items-center justify-center backdrop-blur-sm">
                            <i class="fas fa-shield-alt text-white text-2xl"></i>
                        </div>
                        <div>
                            <h1 class="text-3xl font-bold text-white">System Control Center</h1>
                            <p class="text-blue-100 text-lg">Welcome back, Administrator</p>
                        </div>
                    </div>
                    <p class="text-blue-100/90 mt-4 max-w-2xl">
                        Monitor system performance, manage educational trusts, and oversee the School ERP ecosystem.
                    </p>
                </div>
                <div class="hidden lg:block">
                    <div class="h-20 w-20 bg-white/10 rounded-xl flex items-center justify-center backdrop-blur-sm border border-white/20">
                        <i class="fas fa-desktop text-white text-3xl"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- System Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <!-- Total Trusts -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="h-12 w-12 bg-blue-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-building text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-600">Total Trusts</p>
                        <p class="text-2xl font-bold text-gray-900" x-text="stats.totalTrusts || '0'">0</p>
                    </div>
                </div>
                <div class="text-right">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <i class="fas fa-arrow-up text-xs mr-1"></i>
                        Active
                    </span>
                </div>
            </div>
        </div>

        <!-- Active Users -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="h-12 w-12 bg-green-100 rounded-lg flex items-center justify-center">
                        <i class="fas fa-users text-green-600 text-xl"></i>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-600">Active Users</p>
                        <p class="text-2xl font-bold text-gray-900" x-text="stats.activeUsers || '0'">0</p>
                    </div>
                </div>
                <div class="text-right">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                        <i class="fas fa-users text-xs mr-1"></i>
                        Online
                    </span>
                </div>
            </div>
        </div>

        <!-- System Health -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="h-12 w-12 rounded-lg flex items-center justify-center"
                         :class="stats.systemHealth === 'healthy' ? 'bg-green-100' : 'bg-red-100'">
                        <i class="fas text-xl"
                           :class="stats.systemHealth === 'healthy' ? 'fa-check-circle text-green-600' : 'fa-exclamation-triangle text-red-600'"></i>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-600">System Health</p>
                        <p class="text-lg font-bold capitalize"
                           :class="stats.systemHealth === 'healthy' ? 'text-green-700' : 'text-red-700'"
                           x-text="stats.systemHealth || 'checking'">Checking</p>
                    </div>
                </div>
                <div class="text-right">
                    <div class="h-3 w-3 rounded-full animate-pulse"
                         :class="stats.systemHealth === 'healthy' ? 'bg-green-500' : 'bg-red-500'"></div>
                </div>
            </div>
        </div>

        <!-- Database Status -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition-shadow duration-200">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-3">
                    <div class="h-12 w-12 rounded-lg flex items-center justify-center"
                         :class="stats.databaseStatus === 'connected' ? 'bg-purple-100' : 'bg-amber-100'">
                        <i class="fas fa-database text-xl"
                           :class="stats.databaseStatus === 'connected' ? 'text-purple-600' : 'text-amber-600'"></i>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-gray-600">Database</p>
                        <p class="text-lg font-bold capitalize"
                           :class="stats.databaseStatus === 'connected' ? 'text-purple-700' : 'text-amber-700'"
                           x-text="stats.databaseStatus || 'checking'">Checking</p>
                    </div>
                </div>
                <div class="text-right">
                    <div class="h-3 w-3 rounded-full animate-pulse"
                         :class="stats.databaseStatus === 'connected' ? 'bg-purple-500' : 'bg-amber-500'"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center">
            <i class="fas fa-bolt text-blue-600 mr-2"></i>
            Quick Actions
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            
            <!-- Create New Trust -->
            <button @click="showCreateTrustModal = true" 
                    class="group p-4 border-2 border-dashed border-gray-300 rounded-lg hover:border-blue-400 hover:bg-blue-50 transition-colors duration-200 text-center">
                <div class="h-10 w-10 mx-auto bg-blue-100 group-hover:bg-blue-200 rounded-lg flex items-center justify-center mb-3 transition-colors duration-200">
                    <i class="fas fa-plus text-blue-600 text-lg"></i>
                </div>
                <h4 class="text-sm font-medium text-gray-900 group-hover:text-blue-900">Create New Trust</h4>
                <p class="text-xs text-gray-500 mt-1">Set up educational trust</p>
            </button>

            <!-- System Health -->
            <a href="/admin/system/health" 
               class="group p-4 border border-gray-200 rounded-lg hover:border-green-400 hover:bg-green-50 transition-colors duration-200 text-center">
                <div class="h-10 w-10 mx-auto bg-green-100 group-hover:bg-green-200 rounded-lg flex items-center justify-center mb-3 transition-colors duration-200">
                    <i class="fas fa-heartbeat text-green-600 text-lg"></i>
                </div>
                <h4 class="text-sm font-medium text-gray-900 group-hover:text-green-900">System Health</h4>
                <p class="text-xs text-gray-500 mt-1">Monitor performance</p>
            </a>

            <!-- Manage Users -->
            <a href="/admin/system/users" 
               class="group p-4 border border-gray-200 rounded-lg hover:border-purple-400 hover:bg-purple-50 transition-colors duration-200 text-center">
                <div class="h-10 w-10 mx-auto bg-purple-100 group-hover:bg-purple-200 rounded-lg flex items-center justify-center mb-3 transition-colors duration-200">
                    <i class="fas fa-user-cog text-purple-600 text-lg"></i>
                </div>
                <h4 class="text-sm font-medium text-gray-900 group-hover:text-purple-900">Manage Users</h4>
                <p class="text-xs text-gray-500 mt-1">User administration</p>
            </a>
        </div>
    </div>

    <!-- Trusts Management -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-200 flex justify-between items-center">
            <h3 class="text-lg font-semibold text-gray-900 flex items-center">
                <i class="fas fa-school text-blue-600 mr-2"></i>
                Educational Trusts
            </h3>
            <button @click="refreshTrusts()" 
                    class="inline-flex items-center px-3 py-2 text-sm font-medium text-blue-600 hover:text-blue-800 hover:bg-blue-50 rounded-lg transition-colors duration-200"
                    :disabled="loading">
                <i class="fas fa-sync-alt mr-2" :class="{ 'animate-spin': loading }"></i>
                Refresh
            </button>
        </div>
        
        <div class="p-6">
            <!-- Loading State -->
            <div x-show="loading" class="text-center py-8">
                <div class="inline-flex items-center justify-center h-8 w-8 animate-spin rounded-full border-2 border-gray-300 border-t-blue-600 mb-4"></div>
                <p class="text-sm text-gray-500">Loading trusts...</p>
            </div>

            <!-- Trusts List -->
            <div x-show="!loading && trusts.length > 0" class="space-y-3">
                <template x-for="trust in trusts" :key="trust.id">
                    <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors duration-200">
                        <div class="flex items-center space-x-4 flex-1">
                            <div class="h-12 w-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg flex items-center justify-center text-white font-bold text-sm"
                                 x-text="trust.trust_name?.substring(0, 2)?.toUpperCase() || 'TR'"></div>
                            <div class="flex-1 min-w-0">
                                <h4 class="text-sm font-medium text-gray-900 truncate" x-text="trust.trust_name || 'Unnamed Trust'"></h4>
                                <div class="flex items-center space-x-4 mt-1">
                                    <p class="text-xs text-gray-500" x-text="trust.trust_code || 'No Code'"></p>
                                    <p class="text-xs text-gray-500" x-text="trust.contact_email || 'No Email'"></p>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center space-x-3">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"
                                  :class="{
                                      'bg-green-100 text-green-800': trust.status === 'ACTIVE',
                                      'bg-red-100 text-red-800': trust.status === 'INACTIVE',
                                      'bg-yellow-100 text-yellow-800': trust.status === 'SUSPENDED',
                                      'bg-blue-100 text-blue-800': trust.status === 'SETUP_PENDING'
                                  }"
                                  x-text="trust.status || 'Unknown'"></span>
                            <div class="flex space-x-2">
                                <button @click="viewTrust(trust)" 
                                        class="text-blue-600 hover:text-blue-800 text-sm font-medium px-2 py-1 rounded hover:bg-blue-50 transition-colors duration-200">
                                    <i class="fas fa-eye mr-1"></i>View
                                </button>
                                <button @click="editTrust(trust)" 
                                        class="text-gray-600 hover:text-gray-800 text-sm font-medium px-2 py-1 rounded hover:bg-gray-50 transition-colors duration-200">
                                    <i class="fas fa-edit mr-1"></i>Edit
                                </button>
                            </div>
                        </div>
                    </div>
                </template>
            </div>

            <!-- Empty State -->
            <div x-show="!loading && trusts.length === 0" class="text-center py-12">
                <div class="h-24 w-24 mx-auto bg-gray-100 rounded-full flex items-center justify-center mb-4">
                    <i class="fas fa-school text-gray-400 text-3xl"></i>
                </div>
                <h3 class="text-lg font-medium text-gray-900 mb-2">No trusts found</h3>
                <p class="text-gray-500 mb-6">Get started by creating your first educational trust</p>
                <button @click="showCreateTrustModal = true" 
                        class="inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors duration-200">
                    <i class="fas fa-plus mr-2"></i>
                    Create First Trust
                </button>
            </div>
        </div>
    </div>

    <!-- Create Trust Modal -->
    <div x-show="showCreateTrustModal" 
         x-transition:enter="ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="ease-in duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-50 overflow-y-auto"
         style="display: none;">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @click="showCreateTrustModal = false"></div>

            <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6"
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95">
                
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 sm:mx-0 sm:h-10 sm:w-10">
                        <i class="fas fa-school text-blue-600"></i>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left flex-1">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Create New Trust</h3>
                        <div class="mt-2">
                            <p class="text-sm text-gray-500">Set up a new educational trust to manage schools and students.</p>
                        </div>
                    </div>
                </div>

                <form @submit.prevent="createTrust()" class="mt-6 space-y-4">
                    <div>
                        <label for="trustName" class="block text-sm font-medium text-gray-700 mb-1">Trust Name *</label>
                        <input type="text" id="trustName" x-model="newTrust.trustName" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                               placeholder="Enter trust name">
                    </div>

                    <div>
                        <label for="trustCode" class="block text-sm font-medium text-gray-700 mb-1">Trust Code</label>
                        <input type="text" id="trustCode" x-model="newTrust.trustCode"
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                               placeholder="Auto-generated from name">
                        <p class="mt-1 text-xs text-gray-500">Leave blank to auto-generate from trust name</p>
                    </div>

                    <div>
                        <label for="contactEmail" class="block text-sm font-medium text-gray-700 mb-1">Contact Email *</label>
                        <input type="email" id="contactEmail" x-model="newTrust.contactEmail" required
                               class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                               placeholder="admin@trust.edu">
                    </div>

                    <div class="mt-6 sm:mt-6 sm:flex sm:flex-row-reverse">
                        <button type="submit" :disabled="creatingTrust"
                                class="w-full inline-flex justify-center items-center rounded-lg border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50">
                            <span x-show="!creatingTrust" class="flex items-center">
                                <i class="fas fa-plus mr-2"></i>Create Trust
                            </span>
                            <span x-show="creatingTrust" class="flex items-center">
                                <i class="fas fa-spinner fa-spin mr-2"></i>Creating...
                            </span>
                        </button>
                        <button type="button" @click="showCreateTrustModal = false"
                                class="mt-3 w-full inline-flex justify-center rounded-lg border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:w-auto sm:text-sm">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function systemAdminDashboard() {
    return {
        loading: true,
        showCreateTrustModal: false,
        creatingTrust: false,
        stats: {
            totalTrusts: 0,
            activeUsers: 0,
            systemHealth: 'checking',
            databaseStatus: 'checking'
        },
        trusts: [],
        newTrust: {
            trustName: '',
            trustCode: '',
            contactEmail: ''
        },

        async loadDashboardData() {
            try {
                this.loading = true;
                
                // Load system stats with comprehensive error handling
                try {
                    const statsResponse = await fetch('/api/v1/admin/system/stats', {
                        credentials: 'same-origin',
                        headers: {
                            'Accept': 'application/json',
                            'Content-Type': 'application/json'
                        }
                    });
                    
                    if (statsResponse.ok) {
                        const statsData = await statsResponse.json();
                        if (statsData.success && statsData.data) {
                            this.stats = { ...this.stats, ...statsData.data };
                        } else {
                            console.warn('Stats API returned unexpected format:', statsData);
                        }
                    } else if (statsResponse.status === 401) {
                        window.location.href = '/auth/login?redirect=' + encodeURIComponent(window.location.pathname);
                        return;
                    } else {
                        console.error('Failed to load stats:', statsResponse.status);
                        this.stats.systemHealth = 'error';
                        this.stats.databaseStatus = 'error';
                    }
                } catch (statsError) {
                    console.error('Stats API error:', statsError);
                    this.stats.systemHealth = 'error';
                    this.stats.databaseStatus = 'error';
                }

                // Load trusts
                await this.refreshTrusts();
                
            } catch (error) {
                console.error('Failed to load dashboard data:', error);
                if (window.notify) {
                    window.notify('error', 'Failed to load dashboard data');
                }
            } finally {
                this.loading = false;
            }
        },

        async refreshTrusts() {
            try {
                const response = await fetch('/api/v1/admin/system/trusts', {
                    credentials: 'same-origin',
                    headers: {
                        'Accept': 'application/json'
                    }
                });
                
                if (response.ok) {
                    const data = await response.json();
                    this.trusts = data.success && Array.isArray(data.data) ? data.data : [];
                } else if (response.status === 401) {
                    window.location.href = '/auth/login?redirect=' + encodeURIComponent(window.location.pathname);
                    return;
                } else {
                    console.error('Failed to load trusts:', response.status);
                    this.trusts = [];
                }
            } catch (error) {
                console.error('Failed to load trusts:', error);
                this.trusts = [];
            }
        },

        async createTrust() {
            if (!this.newTrust.trustName.trim() || !this.newTrust.contactEmail.trim()) {
                if (window.notify) window.notify('error', 'Please fill in required fields');
                return;
            }

            try {
                this.creatingTrust = true;
                
                // Q59 COMPLIANT: Use proper API data structure
                const trustData = {
                    name: this.newTrust.trustName.trim(),
                    contactEmail: this.newTrust.contactEmail.trim(),
                    contactPhone: '+91-0000000000',
                    address: {
                        street: 'Default Address',
                        city: 'Default City',
                        state: 'Default State',
                        zipCode: '000000',
                        country: 'India'
                    },
                    description: `Educational trust created via System Admin Dashboard`
                };
                
                const response = await fetch('/api/v1/admin/system/trusts', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    credentials: 'same-origin',
                    body: JSON.stringify(trustData)
                });

                if (response.ok) {
                    if (window.notify) {
                        window.notify('success', 'Trust created successfully');
                    }
                    this.showCreateTrustModal = false;
                    this.newTrust = { trustName: '', trustCode: '', contactEmail: '' };
                    await Promise.all([this.refreshTrusts(), this.loadDashboardData()]);
                } else if (response.status === 401) {
                    window.location.href = '/auth/login?redirect=' + encodeURIComponent(window.location.pathname);
                } else {
                    const errorText = await response.text();
                    let errorMessage = 'Failed to create trust';
                    try {
                        const errorData = JSON.parse(errorText);
                        errorMessage = errorData.error?.message || errorMessage;
                    } catch {}
                    
                    if (window.notify) window.notify('error', errorMessage);
                }
            } catch (error) {
                console.error('Failed to create trust:', error);
                if (window.notify) window.notify('error', 'Network error creating trust');
            } finally {
                this.creatingTrust = false;
            }
        },

        viewTrust(trust) {
            window.location.href = `/admin/system/trusts/${trust.id}`;
        },

        editTrust(trust) {
            window.location.href = `/admin/system/trusts/${trust.id}/edit`;
        }
    };
}
</script>