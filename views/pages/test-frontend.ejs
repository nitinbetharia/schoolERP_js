<!-- Test Page Content -->
<div class="max-w-4xl mx-auto">
   <div class="bg-white shadow-lg rounded-lg overflow-hidden">
      <!-- Header -->
      <div class="bg-gradient-to-r from-blue-600 to-purple-600 px-6 py-4">
         <h1 class="text-2xl font-bold text-white">Tailwind CSS Test Page</h1>
         <p class="text-blue-100 mt-1">Testing if all styles are loading correctly</p>
      </div>

      <!-- Content -->
      <div class="p-6 space-y-6">
         <!-- Colors Test -->
         <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Color System Test</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
               <div class="bg-red-500 text-white p-4 rounded-lg text-center">Red</div>
               <div class="bg-green-500 text-white p-4 rounded-lg text-center">Green</div>
               <div class="bg-blue-500 text-white p-4 rounded-lg text-center">Blue</div>
               <div class="bg-purple-500 text-white p-4 rounded-lg text-center">Purple</div>
            </div>
         </div>

         <!-- Typography Test -->
         <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Typography Test</h2>
            <div class="space-y-2">
               <h1 class="text-4xl font-bold text-gray-900">Heading 1</h1>
               <h2 class="text-3xl font-semibold text-gray-800">Heading 2</h2>
               <h3 class="text-2xl font-medium text-gray-700">Heading 3</h3>
               <p class="text-base text-gray-600">This is a paragraph with regular text.</p>
               <p class="text-sm text-gray-500">This is smaller text.</p>
            </div>
         </div>

         <!-- Components Test -->
         <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Components Test</h2>

            <!-- Buttons -->
            <div class="flex flex-wrap gap-4 mb-6">
               <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-md transition-colors">
                  Primary Button
               </button>
               <button class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-4 py-2 rounded-md transition-colors">
                  Secondary Button
               </button>
               <button
                  class="border border-blue-600 text-blue-600 hover:bg-blue-50 px-4 py-2 rounded-md transition-colors">
                  Outline Button
               </button>
            </div>

            <!-- Form Elements -->
            <div class="grid md:grid-cols-2 gap-4 mb-6">
               <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Text Input</label>
                  <input
                     type="text"
                     class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                     placeholder="Enter text here" />
               </div>
               <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Select</label>
                  <select
                     class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                     <option>Option 1</option>
                     <option>Option 2</option>
                     <option>Option 3</option>
                  </select>
               </div>
            </div>

            <!-- Alert -->
            <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-md">
               <div class="flex items-center">
                  <i class="fas fa-check-circle mr-2"></i>
                  <span>This is a success alert!</span>
               </div>
            </div>
         </div>

         <!-- Responsive Grid Test -->
         <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Responsive Grid Test</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
               <div class="bg-blue-100 p-4 rounded-lg">
                  <h3 class="font-semibold text-blue-800">Card 1</h3>
                  <p class="text-blue-600 text-sm">Responsive grid item</p>
               </div>
               <div class="bg-green-100 p-4 rounded-lg">
                  <h3 class="font-semibold text-green-800">Card 2</h3>
                  <p class="text-green-600 text-sm">Responsive grid item</p>
               </div>
               <div class="bg-purple-100 p-4 rounded-lg">
                  <h3 class="font-semibold text-purple-800">Card 3</h3>
                  <p class="text-purple-600 text-sm">Responsive grid item</p>
               </div>
            </div>
         </div>

         <!-- Font Awesome Test -->
         <div>
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Font Awesome Icons Test</h2>
            <div class="flex flex-wrap gap-4 text-2xl">
               <i class="fas fa-home text-blue-500"></i>
               <i class="fas fa-user text-green-500"></i>
               <i class="fas fa-cog text-gray-500"></i>
               <i class="fas fa-bell text-yellow-500"></i>
               <i class="fas fa-heart text-red-500"></i>
               <i class="fas fa-star text-purple-500"></i>
            </div>
         </div>

         <!-- Alpine.js Test -->
         <div x-data="{ count: 0, message: 'Hello Alpine!' }">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Alpine.js Test</h2>
            <div class="bg-gray-50 p-4 rounded-lg">
               <p class="mb-4">Counter: <span class="font-bold text-blue-600" x-text="count"></span></p>
               <p class="mb-4">Message: <span class="font-bold text-green-600" x-text="message"></span></p>
               <div class="flex gap-2">
                  <button
                     @click="count++"
                     class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-md transition-colors">
                     Increment
                  </button>
                  <button
                     @click="count--"
                     class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-md transition-colors">
                     Decrement
                  </button>
                  <button
                     @click="message = message === 'Hello Alpine!' ? 'Alpine.js is working!' : 'Hello Alpine!'"
                     class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-md transition-colors">
                     Toggle Message
                  </button>
               </div>
            </div>
         </div>
      </div>

      <!-- Footer -->
      <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
         <p class="text-sm text-gray-600">
            ✅ If you can see styled content above, Tailwind CSS is loading correctly!<br />
            ✅ If icons are visible, Font Awesome is loading correctly!<br />
            ✅ If the counter and toggle work, Alpine.js is loading correctly!
         </p>
      </div>
   </div>
</div>
