<!-- Trust Admin Navigation -->
<nav class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
            <!-- Left side - Logo and Navigation -->
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <div class="flex items-center">
                        <div class="h-8 w-8 bg-brand-primary rounded-lg flex items-center justify-center">
                            <i class="fas fa-school text-white text-sm"></i>
                        </div>
                        <span class="ml-2 text-xl font-bold text-gray-900">
                            <%= tenant ? tenant.name : 'Trust Admin' %>
                        </span>
                    </div>
                </div>
                
                <!-- Desktop Navigation Links -->
                <div class="hidden md:ml-8 md:flex md:items-center md:space-x-4">
                    <a href="/dashboard" 
                       class="text-gray-700 hover:text-brand-primary px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors duration-200">
                        <i class="fas fa-tachometer-alt mr-2"></i>Dashboard
                    </a>
                    <a href="/schools" 
                       class="text-gray-700 hover:text-brand-primary px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors duration-200">
                        <i class="fas fa-building mr-2"></i>Schools
                    </a>
                    <a href="/students" 
                       class="text-gray-700 hover:text-brand-primary px-3 py-2 rounded-md text-sm font-medium flex items-center transition-colors duration-200">
                        <i class="fas fa-user-graduate mr-2"></i>Students
                    </a>
                </div>
            </div>

            <!-- Right side - User Menu -->
            <div class="flex items-center">
                <div x-data="{ userMenuOpen: false }" class="relative">
                    <button @click="userMenuOpen = !userMenuOpen"
                            class="flex items-center space-x-3 text-sm rounded-lg p-2 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-brand-primary transition-colors duration-200">
                        <div class="h-8 w-8 rounded-full bg-brand-primary flex items-center justify-center">
                            <span class="text-xs font-medium text-white uppercase">
                                <%= user ? user.name ? user.name.substring(0, 2) : user.email.substring(0, 2) : 'TA' %>
                            </span>
                        </div>
                        <div class="text-left hidden md:block">
                            <p class="font-medium text-gray-900"><%= user ? user.name || user.email : 'Trust Admin' %></p>
                            <p class="text-xs text-gray-500">Trust Administrator</p>
                        </div>
                        <i class="fas fa-chevron-down text-gray-400"></i>
                    </button>
                    
                    <!-- Dropdown menu -->
                    <div x-show="userMenuOpen" 
                         x-transition:enter="transition ease-out duration-200"
                         x-transition:enter-start="transform opacity-0 scale-95"
                         x-transition:enter-end="transform opacity-100 scale-100"
                         x-transition:leave="transition ease-in duration-75"
                         x-transition:leave-start="transform opacity-100 scale-100"
                         x-transition:leave-end="transform opacity-0 scale-95"
                         @click.away="userMenuOpen = false"
                         class="origin-top-right absolute right-0 mt-2 w-56 rounded-md shadow-lg bg-white ring-1 ring-black ring-opacity-5 z-50"
                         style="display: none;">
                        <div class="py-1">
                            <div class="px-4 py-2 border-b border-gray-100">
                                <p class="text-sm font-medium text-gray-900"><%= user ? user.email : 'admin@trust.edu' %></p>
                                <p class="text-xs text-gray-500">Trust Administrator</p>
                            </div>
                            <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 flex items-center">
                                <i class="fas fa-user-circle mr-3 text-gray-400"></i>Profile Settings
                            </a>
                            <div class="border-t border-gray-100"></div>
                            <form method="POST" action="/auth/logout">
                                <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-red-700 hover:bg-red-50 flex items-center">
                                    <i class="fas fa-sign-out-alt mr-3 text-red-400"></i>Sign out
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>