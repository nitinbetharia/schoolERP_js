<!-- Google Fonts - Professional typography (Q3 ENFORCED) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- Font Awesome 6 Free - Icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" 
      integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" 
      crossorigin="anonymous" referrerpolicy="no-referrer">

<!-- Tailwind CSS (Q3 ENFORCED) with integrity check -->
<script src="https://cdn.tailwindcss.com" 
        integrity="sha384-T4Py5MD0FrH0eSUXF2YFHnLyqhQTjT9MwP+UF0sEyY2VPrKo3Xwx8jKm5FlR4JqX" 
        crossorigin="anonymous"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        fontFamily: {
          'sans': ['Inter', '-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'sans-serif']
        },
        animation: {
          'fade-in': 'fadeIn 0.3s ease-in-out',
          'slide-up': 'slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1)',
          'shake': 'shake 0.5s ease-in-out'
        }
      }
    }
  }
</script>

<!-- Alpine.js (Client-side reactivity) with integrity check -->
<script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js" 
        integrity="sha384-Wb3NG7NgRTt1aqjQRBt/P37M7Z8k/TaFZ3B/sZrr25T6JnXHaBGT8yNKmhPm8Jm4" 
        crossorigin="anonymous"></script>

<!-- Custom CSS -->
<link rel="stylesheet" href="/static/css/app.css">

<!-- Favicon -->
<% if (tenant && tenant.branding && tenant.branding.favicon) { %>
<link rel="icon" type="image/png" href="<%= tenant.branding.favicon %>">
<% } else { %>
<link rel="icon" type="image/png" href="/static/images/favicon.png">
<% } %>