<style>
  :root {
    <% if (tenant && tenant.branding) { %>
    --primary-color: <%= tenant.branding.primaryColor || '#3B82F6' %>;
    --secondary-color: <%= tenant.branding.secondaryColor || '#64748B' %>;
    --accent-color: <%= tenant.branding.accentColor || '#10B981' %>;
    <% } else { %>
    /* System admin branding - Professional Blue Theme */
    --primary-color: #1E40AF;
    --secondary-color: #1E3A8A;
    --accent-color: #3B82F6;
    <% } %>
    
    --font-primary: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --font-mono: 'SF Mono', Monaco, 'Cascadia Code', Consolas, monospace;
  }
  
  body { 
    font-family: var(--font-primary);
    font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
  }
  
  /* Animation keyframes */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  
  @keyframes slideUp {
    from { transform: translateY(10px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }
  
  /* Custom utility classes */
  .fade-in {
    animation: fadeIn 0.3s ease-in-out;
  }
  
  .slide-up {
    animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .animate-shake {
    animation: shake 0.5s ease-in-out;
  }
  
  /* Brand color utilities */
  .brand-primary { background-color: var(--primary-color); }
  .brand-secondary { background-color: var(--secondary-color); }
  .brand-accent { background-color: var(--accent-color); }
  .text-brand-primary { color: var(--primary-color); }
  .text-brand-secondary { color: var(--secondary-color); }
  .text-brand-accent { color: var(--accent-color); }
  .border-brand-primary { border-color: var(--primary-color); }
  .hover\:bg-brand-primary:hover { background-color: var(--primary-color); }
</style>