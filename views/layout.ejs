<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= description || 'School ERP Management System' %>">
    <meta name="author" content="School ERP System">
    <title><%= title %> - <%= tenant ? tenant.name : 'School ERP System' %></title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
          crossorigin="anonymous" referrerpolicy="no-referrer">
    
    <!-- Alpine.js for reactive components -->
    <script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"
            integrity="sha384-iCFNW7T6Q4m4A3xqU/hP5wqUt7LzEP8Uh/dGJO5sK/5Y3h7lQXeQvV8UmOzKoI3"
            crossorigin="anonymous"></script>
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/static/css/app.css">
    
    <!-- Dynamic CSS Variables based on user type -->
    <style>
        :root {
            <% if (tenant && tenant.branding) { %>
            /* Tenant specific branding */
            --primary-color: <%= tenant.branding.primaryColor || '#3B82F6' %>;
            --secondary-color: <%= tenant.branding.secondaryColor || '#64748B' %>;
            --accent-color: <%= tenant.branding.accentColor || '#10B981' %>;
            <% } else if (user && user.role === 'system-admin') { %>
            /* System Admin - Professional Blue */
            --primary-color: #1E40AF;
            --secondary-color: #1E3A8A;
            --accent-color: #3B82F6;
            <% } else if (user && user.role === 'trust-admin') { %>
            /* Trust Admin - Corporate Purple */
            --primary-color: #7C3AED;
            --secondary-color: #5B21B6;
            --accent-color: #8B5CF6;
            <% } else if (user && user.role === 'teacher') { %>
            /* Teacher - Friendly Green */
            --primary-color: #059669;
            --secondary-color: #047857;
            --accent-color: #10B981;
            <% } else { %>
            /* Default - Modern Blue */
            --primary-color: #3B82F6;
            --secondary-color: #1E40AF;
            --accent-color: #60A5FA;
            <% } %>
        }
        
        /* Brand color utilities */
        .brand-primary { background-color: var(--primary-color); }
        .brand-secondary { background-color: var(--secondary-color); }
        .brand-accent { background-color: var(--accent-color); }
        .text-brand-primary { color: var(--primary-color); }
        .text-brand-secondary { color: var(--secondary-color); }
        .text-brand-accent { color: var(--accent-color); }
        .border-brand-primary { border-color: var(--primary-color); }
        .hover\:bg-brand-primary:hover { background-color: var(--primary-color); }
        
        /* Responsive utilities */
        .sidebar-transition { transition: transform 0.3s ease-in-out; }
        .content-transition { transition: margin-left 0.3s ease-in-out; }
        
        /* Loading spinner */
        .spinner { animation: spin 1s linear infinite; }
        @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        
        /* Notification styles */
        .notification-enter { animation: slideIn 0.3s ease-out; }
        .notification-exit { animation: slideOut 0.3s ease-in; }
        @keyframes slideIn { from { transform: translateY(-100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        @keyframes slideOut { from { transform: translateY(0); opacity: 1; } to { transform: translateY(-100%); opacity: 0; } }
    </style>
</head>

<body class="bg-gray-50 font-sans antialiased" x-data="{ 
    sidebarOpen: false,
    darkMode: false,
    notifications: []
}">
    <!-- Main Container -->
    <div class="min-h-screen flex">
        
        <!-- Sidebar - Only show for authenticated users -->
        <% if (user) { %>
        <div class="sidebar-transition fixed inset-y-0 left-0 z-50 w-64 bg-white shadow-xl lg:static lg:inset-0"
             :class="{ '-translate-x-full lg:translate-x-0': !sidebarOpen, 'translate-x-0': sidebarOpen }">
            
            <!-- Logo/Brand Section -->
            <div class="flex items-center justify-center h-16 px-4 bg-brand-primary">
                <h1 class="text-xl font-bold text-white">
                    <% if (tenant && tenant.name) { %>
                        <%= tenant.name %>
                    <% } else { %>
                        School ERP
                    <% } %>
                </h1>
            </div>
            
            <!-- Navigation Menu -->
            <nav class="mt-8 px-4">
                <div class="space-y-2">
                    
                    <% if (user.role === 'system-admin') { %>
                    <!-- System Admin Navigation -->
                    <a href="/system/dashboard" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-tachometer-alt mr-3"></i>
                        <span>System Dashboard</span>
                    </a>
                    <a href="/system/tenants" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-building mr-3"></i>
                        <span>Manage Tenants</span>
                    </a>
                    <a href="/system/users" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-users mr-3"></i>
                        <span>System Users</span>
                    </a>
                    <a href="/system/analytics" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-chart-bar mr-3"></i>
                        <span>Analytics</span>
                    </a>
                    
                    <% } else if (user.role === 'trust-admin') { %>
                    <!-- Trust Admin Navigation -->
                    <a href="/trust/dashboard" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-home mr-3"></i>
                        <span>Dashboard</span>
                    </a>
                    <a href="/trust/schools" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-school mr-3"></i>
                        <span>Schools</span>
                    </a>
                    <a href="/trust/users" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-user-tie mr-3"></i>
                        <span>Staff Management</span>
                    </a>
                    <a href="/trust/reports" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-chart-line mr-3"></i>
                        <span>Reports</span>
                    </a>
                    
                    <% } else if (user.role === 'teacher') { %>
                    <!-- Teacher Navigation -->
                    <a href="/teacher/dashboard" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-chalkboard mr-3"></i>
                        <span>My Classes</span>
                    </a>
                    <a href="/teacher/students" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-users mr-3"></i>
                        <span>Students</span>
                    </a>
                    <a href="/teacher/attendance" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-clipboard-check mr-3"></i>
                        <span>Attendance</span>
                    </a>
                    <a href="/teacher/grades" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                        <i class="fas fa-star mr-3"></i>
                        <span>Grades</span>
                    </a>
                    <% } %>
                    
                    <!-- Common Navigation Items -->
                    <div class="border-t border-gray-200 mt-6 pt-6">
                        <a href="/profile" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                            <i class="fas fa-user mr-3"></i>
                            <span>Profile</span>
                        </a>
                        <a href="/settings" class="nav-item flex items-center px-4 py-3 text-gray-700 rounded-lg hover:bg-brand-primary hover:text-white transition-colors">
                            <i class="fas fa-cog mr-3"></i>
                            <span>Settings</span>
                        </a>
                        <a href="/logout" class="nav-item flex items-center px-4 py-3 text-red-600 rounded-lg hover:bg-red-50 transition-colors">
                            <i class="fas fa-sign-out-alt mr-3"></i>
                            <span>Logout</span>
                        </a>
                    </div>
                </div>
            </nav>
        </div>
        <% } %>
        
        <!-- Main Content Area -->
        <div class="flex-1 flex flex-col" :class="{ 'lg:ml-0': !user }">
            
            <!-- Top Header -->
            <header class="bg-white shadow-sm border-b border-gray-200">
                <div class="flex items-center justify-between px-4 py-3">
                    
                    <!-- Left side - Menu toggle for mobile and page title -->
                    <div class="flex items-center space-x-4">
                        <% if (user) { %>
                        <button @click="sidebarOpen = !sidebarOpen" class="p-2 rounded-md text-gray-400 hover:text-gray-600 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-brand-primary lg:hidden">
                            <i class="fas fa-bars text-xl"></i>
                        </button>
                        <% } %>
                        
                        <div>
                            <h1 class="text-xl font-semibold text-gray-900"><%= title %></h1>
                            <% if (subtitle) { %>
                            <p class="text-sm text-gray-500"><%= subtitle %></p>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Right side - User menu -->
                    <% if (user) { %>
                    <div class="flex items-center space-x-4">
                        <!-- Notifications -->
                        <button class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-full relative">
                            <i class="fas fa-bell text-lg"></i>
                            <span class="absolute top-0 right-0 block h-2 w-2 bg-red-400 rounded-full ring-2 ring-white"></span>
                        </button>
                        
                        <!-- User Profile Dropdown -->
                        <div class="relative" x-data="{ open: false }">
                            <button @click="open = !open" class="flex items-center space-x-3 text-sm rounded-full focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-brand-primary">
                                <div class="flex items-center space-x-2">
                                    <div class="h-8 w-8 rounded-full bg-brand-primary flex items-center justify-center">
                                        <span class="text-white font-medium text-sm">
                                            <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
                                        </span>
                                    </div>
                                    <div class="hidden md:block text-left">
                                        <p class="font-medium text-gray-700"><%= user.name %></p>
                                        <p class="text-xs text-gray-500 capitalize"><%= user.role.replace('-', ' ') %></p>
                                    </div>
                                </div>
                                <i class="fas fa-chevron-down text-gray-400"></i>
                            </button>
                            
                            <div x-show="open" @click.away="open = false" x-transition class="absolute right-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50">
                                <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Your Profile</a>
                                <a href="/settings" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Settings</a>
                                <div class="border-t border-gray-100"></div>
                                <a href="/logout" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">Sign out</a>
                            </div>
                        </div>
                    </div>
                    <% } else { %>
                    <!-- Login/Register for unauthenticated users -->
                    <div class="flex items-center space-x-4">
                        <a href="/login" class="text-brand-primary hover:text-brand-secondary font-medium">Login</a>
                        <a href="/register" class="bg-brand-primary text-white px-4 py-2 rounded-md hover:bg-brand-secondary transition-colors">Get Started</a>
                    </div>
                    <% } %>
                </div>
            </header>
            
            <!-- Flash Messages/Notifications -->
            <% if (typeof flash !== 'undefined' && flash.success) { %>
            <div class="bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-md mx-4 mt-4">
                <div class="flex items-center">
                    <i class="fas fa-check-circle mr-2"></i>
                    <span><%= flash.success %></span>
                </div>
            </div>
            <% } %>
            
            <% if (typeof flash !== 'undefined' && flash.error) { %>
            <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md mx-4 mt-4">
                <div class="flex items-center">
                    <i class="fas fa-exclamation-circle mr-2"></i>
                    <span><%= flash.error %></span>
                </div>
            </div>
            <% } %>
            
            <% if (typeof flash !== 'undefined' && flash.warning) { %>
            <div class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-4 py-3 rounded-md mx-4 mt-4">
                <div class="flex items-center">
                    <i class="fas fa-exclamation-triangle mr-2"></i>
                    <span><%= flash.warning %></span>
                </div>
            </div>
            <% } %>
            
            <% if (typeof flash !== 'undefined' && flash.info) { %>
            <div class="bg-blue-50 border border-blue-200 text-blue-800 px-4 py-3 rounded-md mx-4 mt-4">
                <div class="flex items-center">
                    <i class="fas fa-info-circle mr-2"></i>
                    <span><%= flash.info %></span>
                </div>
            </div>
            <% } %>
            
            <!-- Main Content -->
            <main class="flex-1 px-4 py-6 lg:px-8 overflow-y-auto">
                <%- body %>
            </main>
            
            <!-- Footer -->
            <footer class="bg-white border-t border-gray-200 px-4 py-4 lg:px-8">
                <div class="flex flex-col sm:flex-row justify-between items-center text-sm text-gray-600">
                    <div class="flex items-center space-x-4">
                        <span>&copy; 2025 School ERP System. All rights reserved.</span>
                        <% if (tenant && tenant.name) { %>
                        <span>•</span>
                        <span><%= tenant.name %></span>
                        <% } %>
                    </div>
                    <div class="flex items-center space-x-4 mt-2 sm:mt-0">
                        <a href="/help" class="hover:text-brand-primary">Help</a>
                        <a href="/privacy" class="hover:text-brand-primary">Privacy</a>
                        <a href="/terms" class="hover:text-brand-primary">Terms</a>
                    </div>
                </div>
            </footer>
        </div>
    </div>
    
    <!-- Mobile sidebar overlay -->
    <% if (user) { %>
    <div x-show="sidebarOpen" @click="sidebarOpen = false" 
         x-transition:enter="transition-opacity ease-linear duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition-opacity ease-linear duration-300"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         class="fixed inset-0 z-40 bg-gray-600 bg-opacity-75 lg:hidden">
    </div>
    <% } %>
    
    <!-- JavaScript -->
    <script src="/static/js/app.js"></script>
    
    <!-- Alpine.js initialization and global utilities -->
    <script>
        // Global notification system
        window.showNotification = function(message, type = 'info', duration = 5000) {
            const notification = {
                id: Date.now(),
                message: message,
                type: type,
                show: true
            };
            
            // Add to Alpine.js notifications array if available
            if (window.Alpine && document.querySelector('[x-data]')) {
                const app = Alpine.$data(document.querySelector('[x-data]'));
                if (app.notifications) {
                    app.notifications.push(notification);
                    
                    // Auto-remove after duration
                    setTimeout(() => {
                        const index = app.notifications.findIndex(n => n.id === notification.id);
                        if (index > -1) {
                            app.notifications.splice(index, 1);
                        }
                    }, duration);
                }
            }
        };
        
        // Global loading state
        window.setLoading = function(isLoading) {
            const button = document.querySelector('.loading-btn');
            if (button) {
                if (isLoading) {
                    button.disabled = true;
                    button.innerHTML = '<i class="fas fa-spinner spinner mr-2"></i>Loading...';
                } else {
                    button.disabled = false;
                    button.innerHTML = button.dataset.originalText || 'Submit';
                }
            }
        };
        
        // Set active navigation item
        document.addEventListener('DOMContentLoaded', function() {
            const currentPath = window.location.pathname;
            const navItems = document.querySelectorAll('.nav-item');
            
            navItems.forEach(item => {
                if (item.getAttribute('href') === currentPath) {
                    item.classList.remove('text-gray-700', 'hover:bg-brand-primary', 'hover:text-white');
                    item.classList.add('bg-brand-primary', 'text-white');
                }
            });
        });
    </script>
    
    <!-- Page-specific scripts -->
    <% if (typeof scripts !== 'undefined') { %>
        <% scripts.forEach(script => { %>
            <script src="<%= script %>"></script>
        <% }) %>
    <% } %>
    
    <!-- Inline scripts -->
    <% if (typeof inlineScripts !== 'undefined') { %>
        <script>
            <%= inlineScripts %>
        </script>
    <% } %>
</body>
</html>
